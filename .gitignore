# ── Node ───────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ── Python ─────────────────────────────────────────────────────────────────
backend/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
# Environment files — never commit production secrets
.env
.env.local
.env.production
# .env.development is safe to commit (no secrets)
# .env.example is safe to commit (template only)

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
dev.log
frontend.log
backend.log
sentry*.log

# ── IDE ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?
~$*.docx

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data / PII guard ───────────────────────────────────────────────────────
# Never commit SQLite DBs or sensitive data files
*.sqlite
*.db
*.db-shm
*.db-wal
# Local/generated outputs
_audit/
output/
test-results/
e2e/reports/
tmp_*.json
WORKING_STATE.json

# Docker image / repo should never include local database backups
backend/data/*.backup*
backend/data/*.db.backup*
backend/data/*.bak*
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/source/*.bak*
backend/data/source/*.xlsx.bak_*

# Local throwaway/debug probes
backend/_tmp_*.py

# Non-PII CSVs in backend/data are safe to commit
