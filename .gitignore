# ── Node ───────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ── Python ─────────────────────────────────────────────────────────────────
backend/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
.env

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*

# ── IDE ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data / PII guard ───────────────────────────────────────────────────────
# Never commit SQLite DBs or sensitive data files
*.sqlite
*.db
*.db-shm
*.db-wal
# Non-PII CSVs in backend/data are safe to commit