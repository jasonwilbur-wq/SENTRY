# ── Python cache ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────
.venv/
venv/
env/

# ── Secrets / env files ─────────────────────────────────────────
.env
.env.*

# ── Logs ───────────────────────────────────────────────────────
*.log
sentry_backend.log

# ── Dev/utility scripts (not needed in production image) ────────────
bulk_*.py
build_*.py
import_*.py
generate_*.py
check_*.py
inspect_*.py
link_*.py
morning_*.py
scheduled_*.py
var_score_extractor.py
start_backend.bat

# ── Output files ─────────────────────────────────────────────────
output/

# ── CSV / Excel raw data files ────────────────────────────────────
data/*.csv
data/*.xlsx
data/*.xls

# ── Local database artifacts / generated intelligence exports ─────
# Keep the canonical bundled database available to Docker, but never bake
# backups, WAL/SHM files, local samples, or generated source exports into images.
data/*.backup*
data/*.db.backup*
data/*.db-shm
data/*.db-wal
data/sample_*
data/source/
data/json_reports/
!data/sentry.db
