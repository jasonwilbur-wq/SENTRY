# ── Python cache ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────
.venv/
venv/
env/

# ── Secrets / env files ─────────────────────────────────────────
.env
.env.*

# ── Logs ───────────────────────────────────────────────────────
*.log
sentry_backend.log

