{
  "name": "sentry-framework-manager",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:logic": "vitest run --config vitest.logic.config.ts",
    "test:watch": "vitest",
    "quality": "npm run typecheck && npm run build",
    "backend:test": "cd backend && .venv\\Scripts\\python.exe -m pytest tests -q",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy preview",
    "backend:start": "cd backend && .venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8082",
    "backend:docker": "docker build -t sentry-api ./backend && docker run -p 8082:8082 sentry-api",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth-rbac.spec.ts",
    "test:e2e:report": "playwright show-report e2e/reports"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.34.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
