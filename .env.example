# ────────────────────────────────────────────────────────────────────
# SENTRY v2 — Environment Variable Reference
# Copy this file to .env.development or .env.production and fill in values.
# NEVER commit .env.production with real credentials.
# ────────────────────────────────────────────────────────────────────

# Frontend (Vite) — baked into the static bundle at build time.
# Dev:  leave empty — Vite proxy handles /api/* → localhost:8082
# Prod: set to your Cloud Run backend base URL (no trailing slash)
VITE_API_URL=

# Backend (FastAPI) — set on Cloud Run or in your local shell.
# Comma-separated list of allowed CORS origins.
# Dev:  ALLOWED_ORIGINS=http://localhost:3000

# ── Authentication (PR-01) ─────────────────────────────────────────────────
# SENTRY_AUTH_MODE: "off" (dev, no auth enforced) | "header" (validate X-Sentry-User)
# Default: off — backward compatible with existing dev workflows.
SENTRY_AUTH_MODE=off

# Comma-separated list of admin user IDs (lowercase).
# Admins can access /api/admin/* endpoints and perform destructive operations.
SENTRY_ADMIN_USERS=j0w16ja

# Comma-separated list of all allowed user IDs (admins are included automatically).
# Leave empty to allow all authenticated users (header-present = allowed).
SENTRY_ALLOWED_USERS=
# Prod: ALLOWED_ORIGINS=https://your-firebase-project.web.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000
