# ────────────────────────────────────────────────────────────────────
# SENTRY v2 — Environment Variable Reference
# Copy this file to .env.development or .env.production and fill in values.
# NEVER commit .env.production with real credentials; it is gitignored by design.
# ────────────────────────────────────────────────────────────────────

# Frontend (Vite) — baked into the static bundle at build time.
# Dev:  leave empty — Vite proxy handles /api/* → localhost:8082
# Prod: set to your Cloud Run backend base URL (no trailing slash)
VITE_API_URL=

# Frontend dev identity for temporary header-auth mode.
# Dev only: set this to a user listed in SENTRY_ALLOWED_USERS or SENTRY_ADMIN_USERS.
# Prod should use enterprise auth/OIDC rather than a build-time user header.
VITE_SENTRY_USER=

# Optional hosted auth entry/exit URLs.
# IAP logout can usually default to /_gcp_iap/clear_login_cookie, but set an
# explicit URL if Walmart SSO or the GCP launch path provides one.
VITE_SENTRY_LOGIN_URL=
VITE_SENTRY_LOGOUT_URL=

# Backend (FastAPI) — set on Cloud Run or in your local shell.
# Comma-separated list of allowed CORS origins.
# Dev can omit this to use localhost defaults.
# Prod must set explicit HTTPS origins; startup refuses missing, wildcard, localhost, or http:// origins.
# Prod: ALLOWED_ORIGINS=https://your-firebase-project.web.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Backend auth posture.
# header = local/test only; requires X-Sentry-User and allowlists.
# oidc   = production SSO/OIDC; validates Authorization: Bearer JWT.
# iap    = GCP launch option; validates X-Goog-IAP-JWT-Assertion from Google Cloud IAP.
# off    = development-only bypass; never use in shared or production environments.
SENTRY_AUTH_MODE=header
SENTRY_ALLOWED_USERS=
SENTRY_ADMIN_USERS=
SENTRY_ALLOWED_GROUPS=
SENTRY_ADMIN_GROUPS=

# Production OIDC mode. Use Walmart-approved SSO / Entra / Google Identity config.
SENTRY_OIDC_ISSUER=
SENTRY_OIDC_AUDIENCE=
SENTRY_OIDC_JWKS_URL=
SENTRY_OIDC_USER_CLAIMS=preferred_username,email,upn,sub
SENTRY_OIDC_GROUPS_CLAIM=groups

# Auth failure throttling. This is an app-level guard; keep GCP/IAP or load
# balancer controls enabled for distributed attacks.
SENTRY_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
SENTRY_AUTH_RATE_LIMIT_MAX_FAILURES=30

# GCP IAP mode for Cloud Run behind Identity-Aware Proxy.
# Audience format is provisioned by GCP/IAP, often /projects/PROJECT_NUMBER/global/backendServices/BACKEND_SERVICE_ID.
SENTRY_IAP_AUDIENCE=
SENTRY_IAP_ISSUER=https://cloud.google.com/iap
SENTRY_IAP_JWKS_URL=https://www.gstatic.com/iap/verify/public_key-jwk

# Runtime database location.
# Default: backend/data/sentry.db bundled with the app. For production mutations,
# set this to persistent storage or migrate to Cloud SQL/Postgres.
# Local example: SENTRY_DB_PATH=./backend/data/sentry.local.db
SENTRY_DB_PATH=

# Opt-in strict SQLite FK enforcement after legacy empty-string FK rows are cleaned up.
SENTRY_SQLITE_FOREIGN_KEYS=0
