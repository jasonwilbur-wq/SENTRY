{
  "id": "executive-intel-handoff-contract",
  "version": "0.1.0",
  "mode": "agent_first_sentry_optional_consumer",
  "source_system": "exec-signal-scout",
  "destination": "SENTRY_PROGRAM_OPTIONAL_IMPORT",
  "default_handoff_status": "FINALIZED_FOR_SENTRY_PROGRAM_HANDOFF",
  "draft_handoff_status": "DRAFT_HANDOFF_REVIEW_ONLY",
  "required_signal_conditions": {
    "verification_status": "VERIFIED",
    "analyst_review_status_any_of": [
      "APPROVED_FOR_SENTRY",
      "APPROVED_FOR_CSO_DRAFT"
    ]
  },
  "bundle_sections": [
    "bundle_metadata",
    "profile",
    "summary",
    "signals",
    "sources",
    "validation",
    "source_policy",
    "draft_report_markdown",
    "review_only_controls_enforced",
    "import_notes"
  ],
  "mandatory_review_controls": [
    "NO_SQLITE_WRITES",
    "NO_ARTIFACT_MUTATION",
    "NO_SCHEDULED_COLLECTION",
    "NO_REPORT_PUBLICATION",
    "NO_OUTBOUND_DELIVERY",
    "NO_PRIVATE_CURRENT_LOCATION_TRACKING",
    "NO_AUTH_PAYWALL_CAPTCHA_BYPASS",
    "NO_COMPETITOR_PRICING_ASSORTMENT_OFFERING_SCRAPING"
  ],
  "sentry_import_requires_separate_approval": true
}
